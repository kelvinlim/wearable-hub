# Copy to .env and fill in. Never commit the real .env.

# --- App ---
ENVIRONMENT=dev

# --- Database ---
# External MariaDB at cnc3.med.umn.edu; provision the schema/user there before first start.
DB_NAME=wearable_hub
DB_USER=wearable
DB_PASSWORD=wearable
DATABASE_URL=mysql+pymysql://wearable:wearable@cnc3.med.umn.edu:3306/wearable_hub
# entrypoint.sh waits for the DB on this host:port before running migrations.
DB_WAIT_HOST=cnc3.med.umn.edu
DB_WAIT_PORT=3306

# --- Token encryption at rest (Fernet) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Google Health API / Fitbit OAuth (Milestone 1) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Space-delimited Restricted scopes; copy exact strings from Cloud Console "Data Access".
GOOGLE_HEALTH_SCOPES=
GH_PROJECT_ID=
# Subscriber API addresses the project by NUMBER, not ID (find it on the project dashboard).
GH_PROJECT_NUMBER=
# Client-chosen subscriber id + per-subscriber data types (space-separated) + create policy.
GH_SUBSCRIBER_ID=wearable-hub
GH_SUBSCRIPTION_DATA_TYPES=steps sleep heart_rate
GH_SUBSCRIPTION_CREATE_POLICY=AUTOMATIC

# --- Project credentials for Tier-1 subscriber registration (service account) ---
# Subscriber registration is a PROJECT op (a subject's user token gets 403). Create a
# service account in the project, grant it the Health subscriber-admin role, download a key,
# mount it into the backend container, and point this at the in-container path.
# Empty → falls back to Application Default Credentials.
# Mount ./secrets read-only into the backend (see docker-compose) and point here.
GH_SA_CREDENTIALS_FILE=/secrets/health-sa.json
GH_SA_SCOPES=https://www.googleapis.com/auth/cloud-platform

# --- Public URLs (host: lnpitask.umn.edu, HTTPS required by Google) ---
# Must exactly match the Authorized redirect URI configured in the Cloud Console OAuth client.
OAUTH_REDIRECT_URI=https://lnpitask.umn.edu/enroll/callback
WEBHOOK_PUBLIC_URL=https://lnpitask.umn.edu/webhooks/google-health
# Shared secret to verify inbound webhook notifications (scheme TBD per Google docs).
WEBHOOK_SECRET=

# --- Public path prefix (host namespacing) ---
# The app is reverse-proxied under this prefix on lnpitask (everything at /wearable/...), so the
# subject enroll page emits links/redirects inside the prefix. "" = served at root. The backend
# routes stay unprefixed; the host nginx strips it (see deploy/nginx/wearable-hub.conf).
PUBLIC_PATH_PREFIX=/wearable

# --- Garmin Health API (OAuth 1.0a; second provider) ---
# Consumer key/secret from the Garmin Developer portal. Tokens don't expire; data arrives via the
# per-datatype push webhooks (no subscription API). Leave blank to disable Garmin enrollment.
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
# Subject OAuth callback — register this exact URI in the Garmin portal (shared with the enroll
# flow; the callback dispatches Garmin vs Google by the OAuth params present). Namespaced under
# /wearable/ to avoid colliding with other apps on the host.
GARMIN_OAUTH_REDIRECT_URI=https://lnpitask.umn.edu/wearable/enroll/callback
# Base URLs (override only if Garmin changes them).
# GARMIN_REQUEST_TOKEN_URL=https://connectapi.garmin.com/oauth-service/oauth/request_token
# GARMIN_AUTHORIZE_URL=https://connect.garmin.com/oauthConfirm
# GARMIN_ACCESS_TOKEN_URL=https://connectapi.garmin.com/oauth-service/oauth/access_token
# GARMIN_API_BASE=https://apis.garmin.com/wellness-api/rest
# In the Garmin portal, register the push URLs under /wearable/:
#   https://lnpitask.umn.edu/wearable/webhooks/garmin/dailies (and /sleeps, /hrv,
#   /deregistrations, … one per summary type you enable).

# --- Researcher auth (Google login + RBAC) ---
# Bootstrap superadmin emails (comma-separated) — auto-provisioned as superusers on first
# Google login. REQUIRED, or nobody can sign in. Reuses GOOGLE_CLIENT_ID/SECRET.
SUPERADMIN_EMAILS=
# Researcher login callback — add this exact URI to the Google OAuth client's redirect URIs.
# Local dev: http://localhost:8020/auth/callback
# Path-based prod (host nginx serves the console under /wearable/):
#   https://lnpitask.umn.edu/wearable/auth/callback
RESEARCHER_OAUTH_REDIRECT_URI=http://localhost:8020/auth/callback
